{
  "name": "hostdesk",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api mysql",
    "lint": "eslint .",
    "preview": "vite preview",
    "metrics:static": "node scripts/collect-static-metrics.mjs",
    "metrics:reports": "node scripts/collect-report-metrics.mjs",
    "metrics:all": "npm run metrics:static && npm run test:coverage && npm run audit:json && npm run audit:prod:json && npm run build && npm run lighthouse && npm run metrics:reports",
    "test": "vitest run src",
    "test:api": "vitest run --config vitest.api.config.ts",
    "test:coverage": "vitest run src --coverage",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report metrics/reports/playwright",
    "lighthouse": "node scripts/run-lighthouse.mjs",
    "sbom": "cyclonedx-npm --output-file sbom.cdx.json --output-format JSON",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "audit:all": "npm audit --audit-level=high",
    "audit:json": "mkdir -p metrics/reports && npm audit --json > metrics/reports/npm-audit.json || true",
    "audit:prod:json": "mkdir -p metrics/reports && npm audit --omit=dev --json > metrics/reports/npm-audit-prod.json || true",
    "php:lint": "find api -name '*.php' -print0 | xargs -0 -n1 php -l",
    "data:validate": "node scripts/validate-data-schemas.mjs"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "lucide-react": "0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "4.2.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.58.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "4.0.18",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "chrome-launcher": "1.2.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fast-check": "4.7.0",
    "globals": "^16.5.0",
    "jsdom": "28.1.0",
    "lighthouse": "12.6.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.2",
    "vitest": "4.0.18"
  }
}
