{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hostdesk.local/schemas/scoring-rubric.json",
  "title": "SDR operations scoring rubric schema",
  "description": "Aligns record quality with CRM completeness, hygiene, ICP fit, follow-up discipline, handoff readiness, and reporting coverage.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "focus", "metrics"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "focus": { "type": "string", "minLength": 1 },
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "weight", "description", "max", "suggestion"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "weight": { "type": "number", "minimum": 0, "maximum": 100 },
          "description": { "type": "string", "minLength": 1 },
          "max": { "type": "number", "minimum": 0, "maximum": 100 },
          "suggestion": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
