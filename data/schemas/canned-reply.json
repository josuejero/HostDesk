{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hostdesk.local/schemas/canned-reply.json",
  "title": "Outreach template schema",
  "description": "Captures reusable outreach structures that remain editable before a user logs the activity.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "tone", "category", "segments", "editable", "keywords"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "tone": { "type": "string", "minLength": 1 },
    "category": {
      "type": "string",
      "enum": [
        "first-touch",
        "follow-up",
        "objection-handling",
        "meeting-confirmation",
        "handoff-intro",
        "nurture"
      ]
    },
    "segments": {
      "type": "object",
      "additionalProperties": false,
      "required": ["opener", "valueProp", "nextStep"],
      "properties": {
        "opener": { "type": "string", "minLength": 1 },
        "valueProp": { "type": "string", "minLength": 1 },
        "nextStep": { "type": "string", "minLength": 1 }
      }
    },
    "editable": { "type": "boolean" },
    "keywords": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
