{
  "title": "Ticket schema",
  "summary": "Defines the ticket attributes that HostDesk uses for SLAs, prioritization, and routing.",
  "fields": {
    "id": "string (unique ticket identifier)",
    "subject": "string (brief summary for routing/KB suggestions)",
    "department": "string (target department for triage)",
    "severity": "string (Critical, High, Medium, Low)",
    "priority": "string (Urgent, High, Medium, Low)",
    "status": "string (New, Open, Waiting on Customer, Escalated, Resolved, Closed)",
    "plan": "string (Core, Standard, Pro, Enterprise)",
    "slaTargetMinutes": "number (minutes to hit resolution/update per SLA)",
    "createdAt": "ISO timestamp",
    "assignedTo": "string (agent or team)",
    "escalationTier": "string (Tier 1, Tier 2, Tier 3, SOC)",
    "invoiceState": "string (Paid - Suspended, Active, Past Due, Pending Upgrade, Pending Payment)",
    "recentIncidents": "array of strings (contextual incident log)",
    "thread": "array of ThreadEntry (public/customer messages)",
    "internalNotes": "array of ThreadEntry (internal-only notes)",
    "kbMatches": "array of KB article identifiers",
    "postmortem": "object with rootCause, fix, followUp, prevention",
    "scorecard": "object describing current scoring metrics and total"
  },
  "allowedValues": {
    "departments": [
      "Billing & Accounts",
      "Technical Operations",
      "Infrastructure",
      "Customer Advocacy"
    ],
    "statuses": [
      "New",
      "Open",
      "Waiting on Customer",
      "Escalated",
      "Resolved",
      "Closed"
    ],
    "plans": ["Core", "Standard", "Pro", "Enterprise"],
    "escalationTiers": [
      "Tier 1",
      "Tier 2",
      "Tier 3",
      "SOC"
    ],
    "invoiceStates": [
      "Paid - Suspended",
      "Active",
      "Past Due",
      "Pending Upgrade",
      "Pending Payment"
    ],
    "severities": ["Critical", "High", "Medium", "Low"],
    "priorities": ["Urgent", "High", "Medium", "Low"]
  }
}
