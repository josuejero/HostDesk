{
  "title": "Lead record schema",
  "summary": "Defines the prospect record fields that HostDesk uses for queue routing, cadence, activity logging, and stage gating.",
  "fields": {
    "id": "string (unique record identifier)",
    "subject": "string (brief prospect context for routing and playbook suggestions)",
    "company": "string",
    "segment": "string (MSP, healthcare, education, etc.)",
    "employeeRange": "string",
    "microsoftFootprint": "array of strings describing current Microsoft tooling",
    "useCase": "string (core workload or problem statement)",
    "buyerPersona": "string",
    "leadSource": "string",
    "owner": "string (current SDR or account owner)",
    "stage": "string (New lead, Active, Meeting booked, Handoff ready, Nurture, Disqualified)",
    "stageEnteredAt": "ISO timestamp",
    "createdAt": "ISO timestamp",
    "lastTouchAt": "ISO timestamp",
    "nextTouchDueAt": "ISO timestamp or empty string",
    "painPoints": "array of strings",
    "objections": "array of strings",
    "buyingSignals": "array of strings",
    "activities": "array of typed activity entries",
    "playbookMatches": "array of playbook identifiers",
    "review": "object with deduplication, stageCriteria, nextStepPlan, handoffNotes, playbookStatus",
    "scorecard": "object describing current scoring metrics and total",
    "aiSummary": "string",
    "recommendedNextAction": "string",
    "crmCompleteness": "number (0-100)",
    "disqualificationReason": "string"
  },
  "allowedValues": {
    "stages": [
      "New lead",
      "Active",
      "Meeting booked",
      "Handoff ready",
      "Nurture",
      "Disqualified"
    ],
    "activityTypes": [
      "outbound-email",
      "call-attempt",
      "linkedin-touch",
      "reply-received",
      "meeting-booked",
      "enrichment-update",
      "ownership-changed",
      "stage-changed",
      "ai-draft-used",
      "note-added"
    ],
    "playbookStatus": ["updated", "not-needed", ""]
  }
}
