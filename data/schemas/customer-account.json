{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hostdesk.local/schemas/customer-account.json",
  "title": "Account profile schema",
  "description": "Describes regional context, current stack, and Microsoft workload priority that shape routing and handoff context.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "accountId",
    "name",
    "timezone",
    "region",
    "existingStack",
    "microsoftPriority",
    "motion"
  ],
  "properties": {
    "accountId": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "timezone": { "type": "string", "minLength": 1 },
    "region": { "type": "string", "minLength": 1 },
    "existingStack": { "type": "string", "minLength": 1 },
    "microsoftPriority": { "type": "string", "minLength": 1 },
    "motion": { "type": "string", "minLength": 1 }
  }
}
