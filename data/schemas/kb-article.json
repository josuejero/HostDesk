{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hostdesk.local/schemas/kb-article.json",
  "title": "Playbook schema",
  "description": "Defines the metadata used for keyword matching and playbook suggestions inside the sales-ops workflow.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "summary", "keywords", "labels", "focusArea", "link"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "keywords": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "labels": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "focusArea": { "type": "string", "minLength": 1 },
    "link": { "type": "string", "format": "uri" }
  }
}
