@media (max-width: 1280px) {
  .workspace-grid {
    grid-template-columns: 220px minmax(320px, 1fr);
  }

  .detail-column {
    order: 3;
    grid-column: 1 / -1;
  }

  .views-nav {
    position: static;
    max-height: none;
    overflow: visible;
  }
}

@media (max-width: 900px) {
  .workspace-grid {
    grid-template-columns: 1fr;
  }

  .app-header {
    flex-direction: column;
  }

  .tickets-column,
  .detail-column,
  .views-nav {
    width: 100%;
  }

  .detail-column {
    grid-column: auto;
  }
}
