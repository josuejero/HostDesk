  flex-direction: column;
  gap: 0.9rem;
  flex: 1;
  overflow-y: auto;
  min-height: 0;
}

.empty-state {
  border: 1px dashed rgba(255, 255, 255, 0.4);
  border-radius: 14px;
  padding: 1.5rem;
  text-align: center;
  background: rgba(2, 6, 18, 0.75);
  color: rgba(255, 255, 255, 0.85);
