<file path="src/app/styles/conversation.css">
.conversation-body {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  min-width: 0;
}

.conversation-stream {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  max-height: 320px;
  overflow-y: auto;
  padding-right: 0.25rem;
  min-width: 0;
}

.conversation-bubble {
  border-radius: 14px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  padding: 0.85rem;
  max-width: min(46rem, 85%);
  min-width: 0;
  box-shadow: 0 10px 20px rgba(3, 6, 15, 0.3);
  background: rgba(255, 255, 255, 0.02);
}

.conversation-bubble p {
  margin: 0;
  overflow-wrap: anywhere;
}

.conversation-bubble--customer {
  align-self: flex-start;
  border-color: rgba(130, 199, 255, 0.5);
  background: rgba(130, 199, 255, 0.12);
}

.conversation-bubble--agent {
  align-self: flex-end;
  border-color: rgba(103, 246, 160, 0.5);
  background: rgba(103, 246, 160, 0.16);
}

.conversation-bubble__meta {
  display: flex;
  justify-content: space-between;
  gap: 0.75rem;
  flex-wrap: wrap;
  font-size: 0.78rem;
  color: rgba(245, 246, 255, 0.78);
  margin-bottom: 0.35rem;
}

.attachments-placeholder {
  border: 1px dashed rgba(255, 255, 255, 0.35);
  border-radius: 12px;
