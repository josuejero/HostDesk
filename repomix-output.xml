<file path="src/app/styles/tickets.css">
.ticket-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.9rem;
  flex: 1;
  overflow-y: auto;
  min-height: 0;
}

.empty-state {
  border: 1px dashed rgba(255, 255, 255, 0.4);
  border-radius: 14px;
  padding: 1.5rem;
  text-align: center;
  background: rgba(2, 6, 18, 0.75);
  color: rgba(255, 255, 255, 0.85);
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  font-size: 0.95rem;
}

.empty-state p {
  margin: 0;
}

.ticket-card {
  background: rgba(255, 255, 255, 0.02);
  border-radius: 16px;
  border: 1px solid rgba(255, 255, 255, 0.05);
  padding: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.65rem;
  cursor: pointer;
  transition:
    border-color 0.2s ease,
    transform 0.2s ease,
    background 0.2s ease,
    box-shadow 0.2s ease;
  width: 100%;
  text-align: left;
  text-decoration: none;
  font: inherit;
  color: inherit;
  appearance: none;
}

.ticket-card:hover {
  border-color: rgba(130, 199, 255, 0.4);
}

.ticket-card.active {
  border-color: #67f6a0;
  background: rgba(103, 246, 160, 0.08);
  transform: translateY(-1px);
  box-shadow: 0 15px 30px rgba(3, 6, 15, 0.6);
}

.ticket-card:focus-visible {
  outline: none;
  box-shadow: 0 0 0 3px rgba(130, 199, 255, 0.45), 0 15px 30px rgba(3, 6, 15, 0.35);
}

.ticket-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 0.75rem;
  min-width: 0;
}

.ticket-card-top > div:first-child {
  flex: 1;
  min-width: 0;
}

.ticket-card-top h3 {
  margin: 0;
  font-size: 1rem;
  overflow-wrap: anywhere;
}

.ticket-card-subtext {
  margin: 0.35rem 0 0;
  font-size: 0.85rem;
  color: rgba(245, 246, 255, 0.72);
}

.ticket-card-timer,
.sla {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.85rem;
  flex-shrink: 0;
}

.ticket-card-timer svg,
.sla svg {
  stroke: currentColor;
}

.timer-normal {
  color: #67f6a0;
}

.timer-warning {
  color: #facc15;
}

.timer-overdue {
  color: #ff6b6b;
  font-weight: 600;
}

.timer-missing {
  color: #ffb347;
  font-weight: 600;
}

.ticket-card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.badge {
  font-size: 0.75rem;
  padding: 0.35rem 0.7rem;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.35);
  background: rgba(7, 9, 24, 0.75);
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-weight: 600;
  color: #f5f6ff;
  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
}

.badge span {
  display: inline-flex;
  align-items: center;
  gap: 0.15rem;
}

.badge svg {
  width: 1rem;
  height: 1rem;
  stroke-width: 1.5;
  stroke: currentColor;
}

.badge.department {
  background: rgba(103, 246, 160, 0.12);
  border-color: rgba(103, 246, 160, 0.5);
  color: #c7ffe9;
}

.badge.status {
  background: rgba(130, 199, 255, 0.15);
  border-color: rgba(130, 199, 255, 0.45);
  color: #9ad8ff;
}

.badge.priority {
  background: rgba(255, 179, 71, 0.15);
  border-color: rgba(255, 179, 71, 0.35);
  color: #ffd35a;
}

.badge.severity {
  background: rgba(255, 107, 107, 0.18);
  border-color: rgba(255, 107, 107, 0.45);
  color: #ffb0b0;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
}

.tag {
  font-size: 0.75rem;
  border-radius: 8px;
  padding: 0.25rem 0.75rem;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

@media (max-width: 640px) {
  .ticket-card-top {
    flex-direction: column;
  }

  .ticket-card-timer {
    align-self: flex-start;
  }
}
</file>

